{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "outDir": "./dist-server",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "db/*": ["./db/*"],
      "contracts/*": ["./contracts/*"]
    },
    "types": ["node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": false
  },
  "include": ["api/**/*", "db/**/*", "contracts/**/*", "server.ts"],
  "exclude": ["node_modules", "dist", "dist-server", "src"]
}
